---
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden pt-16">
  <div class="absolute inset-0 bg-darker">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-accent/5 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-accent/5 rounded-full blur-[120px]"></div>
  </div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center min-h-[80vh]">
      <!-- Text side -->
      <div class="text-center lg:text-left order-2 lg:order-1">
        <span class="inline-block px-4 py-1.5 bg-accent/10 border border-accent/20 rounded-full text-sm text-accent tracking-widest uppercase mb-6">
          Guadalajara, Jalisco
        </span>
        
        <h1 class="text-6xl sm:text-7xl lg:text-8xl font-serif font-black tracking-tighter mb-4 leading-none">
          <span class="text-white">Nurse</span><br>
          <span class="text-accent">Tatto</span>
        </h1>
        
        <p class="text-xl font-medium text-ashes/40 mb-2 tracking-wider">
          by <span class="text-accent font-bold">Lajami</span>
        </p>
        
        <p class="text-ashes/50 max-w-md mx-auto lg:mx-0 mb-8 leading-relaxed">
          Precisión quirúrgica. Actitud rebelde.<br>
          Arte corporal que deja huella desde 2019.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center lg:items-start justify-center lg:justify-start gap-4 mb-10">
          <a 
            href="https://wa.me/5213313960137" 
            target="_blank"
            class="px-8 py-4 bg-accent hover:bg-accent-light text-darker font-bold rounded transition-all hover:scale-105"
          >
            Agenda tu cita
          </a>
          <a 
            href="#portafolio" 
            class="px-8 py-4 border border-white/20 hover:border-accent text-ashes hover:text-accent font-bold rounded transition-all"
          >
            Ver trabajos
          </a>
        </div>
        
        <div class="flex items-center justify-center lg:justify-start gap-8 text-ashes/30 text-sm">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            500+ tatuajes
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            5 años
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Esterilidad
          </span>
        </div>
      </div>
      
      <!-- Logo side -->
      <div class="relative order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative w-80 sm:w-96 lg:w-[420px]">
          <!-- Logo -->
          <div class="relative rounded-2xl overflow-hidden border border-ashes/10 bg-darker/80 p-8">
            <img 
              src={`${baseUrl}logo-estudio.png`} 
              alt="NurseTatto Logo" 
              class="w-full h-auto object-contain drop-shadow-[0_0_30px_rgba(133,151,167,0.3)]"
            >
          </div>

        </div>
      </div>
    </div>
  </div>
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-accent/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
